// YU.R Skin Solution — Prisma schema
// Database: PostgreSQL (Supabase)
// Strategy: core scalar fields on the main models; localised fields live in
// *Translation child tables keyed by (parentId, locale) so Sofia can translate
// EN/NL/FR/RU side-by-side in the admin without schema changes.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL") // for migrations via Supabase pooler
  extensions = [pgcrypto]
}

// ────────────────────────────────────────────────────────────────────────────
//  LOCALES
// ────────────────────────────────────────────────────────────────────────────

enum Locale {
  EN
  NL
  FR
  RU
}

// ────────────────────────────────────────────────────────────────────────────
//  USERS / CUSTOMERS / ADMIN
// ────────────────────────────────────────────────────────────────────────────
//  `User.id` matches Supabase `auth.users.id` (UUID). We don't duplicate
//  passwords — Supabase Auth handles that. We keep profile + role + shop data.

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  role          Role       @default(CUSTOMER)
  firstName     String?
  lastName      String?
  phone         String?
  preferredLocale Locale   @default(EN)
  marketingOptIn Boolean   @default(false)
  marketingOptInAt DateTime?
  acceptsTermsAt DateTime?

  // Optional DOB — drives the birthday-email cron (#186). Stored as a
  // DateTime so Prisma stays happy, but only the month/day matter to us.
  birthday      DateTime?
  // Calendar year of the most recent birthday email we sent, used as a
  // sentinel to prevent the daily cron from re-sending if it runs twice
  // on the same day or if Sofia hand-fires it for testing.
  lastBirthdayEmailedYear Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?  // GDPR soft-delete

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlist      WishlistItem[]
  carts         Cart[]
  conversations AiConversation[]
  contactMessages ContactMessage[]
  returns       ReturnRequest[]
  subscriptions ProductSubscription[]
  loyaltyAccount LoyaltyAccount?

  @@index([role])
  @@index([deletedAt])
}

model Address {
  id         String   @id @default(uuid()) @db.Uuid
  // null = guest-checkout address (snapshot for the order; no account to
  // attach it to yet). Logged-in checkouts + addresses saved from the
  // account area always carry a userId.
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault  Boolean  @default(false)
  type       AddressType @default(SHIPPING)
  firstName  String
  lastName   String
  company    String?
  line1      String
  line2      String?
  city       String
  postcode   String
  region     String?
  country    String   // ISO 3166-1 alpha-2 (BE, NL, FR, DE, …)
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderShipments Order[] @relation("shipping")
  orderBilling   Order[] @relation("billing")
  // ProductSubscription snapshots the shipping address at signup so a
  // later edit doesn't reroute pending shipments — the FK lives on the
  // ProductSubscription, this is just the opposite side Prisma needs.
  productSubscriptions ProductSubscription[]

  @@index([userId])
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

// ────────────────────────────────────────────────────────────────────────────
//  CATALOGUE — brands, categories, products, variants, media
// ────────────────────────────────────────────────────────────────────────────

model Brand {
  id         String             @id @default(uuid()) @db.Uuid
  slug       String             @unique
  name       String
  isActive   Boolean            @default(true)
  logoUrl    String?
  // Country the brand is based in. ISO-3166 alpha-2, e.g. "KR" for YU.R.
  // Mirrors the supplier sheet's "Brand country" column. Stored once per
  // brand instead of per product (where it would duplicate 35-200x with
  // no extra information). PDPs can render "Brand from {country}" by
  // joining through Product.brand.country.
  country    String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  translations BrandTranslation[]
  products   Product[]
}

model BrandTranslation {
  id        String  @id @default(uuid()) @db.Uuid
  brandId   String  @db.Uuid
  brand     Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  locale    Locale
  tagline   String?
  story     String? // rich HTML
  @@unique([brandId, locale])
}

model Category {
  id         String   @id @default(uuid()) @db.Uuid
  slug       String   @unique
  parentId   String?  @db.Uuid
  parent     Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  iconUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  translations CategoryTranslation[]
  products   ProductCategory[]
}

model CategoryTranslation {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     Locale
  name       String
  description String?  // rich HTML for category landing page
  seoTitle   String?
  seoDescription String?
  @@unique([categoryId, locale])
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Distinguishes ordinary inventory from special non-physical products.
// GIFT_CARD turns a Product row into a configurable digital good — variants
// = denominations (€25/€50/…), no shipping, custom PDP form, and the Mollie
// webhook mints a real GiftCard row for each unit purchased.
enum ProductKind {
  STANDARD
  GIFT_CARD
}

// Supplier classifies products by gender / age cohort. Most YU.R items are
// UNISEX; the others are kept so PDP filters and supplier round-trips stay
// honest. Add new values when new product lines arrive (e.g. PETS).
enum AudienceCategory {
  UNISEX
  WOMEN
  MEN
  KIDS
  BABIES
}

model Product {
  id              String          @id @default(uuid()) @db.Uuid
  sku             String          @unique           // human-friendly SKU e.g. "YUR-SUN-SPF50"
  brandId         String?         @db.Uuid
  brand           Brand?          @relation(fields: [brandId], references: [id])
  status          ProductStatus   @default(DRAFT)
  // STANDARD = a normal physical product. GIFT_CARD = digital good — the
  // PDP swaps in a recipient form, the Mollie webhook mints a real
  // GiftCard row per purchased unit, and shipping is skipped at checkout.
  kind            ProductKind     @default(STANDARD)
  isFeatured      Boolean         @default(false)
  isBestseller    Boolean         @default(false)
  isAvailableForAi Boolean        @default(true)    // admin toggle: can the AI concierge recommend this?
  hideFromSearch  Boolean         @default(false)
  price           Decimal         @db.Decimal(10, 2) // base price in EUR
  comparePrice    Decimal?        @db.Decimal(10, 2) // "was" price for sale display
  cost            Decimal?        @db.Decimal(10, 2) // cost of goods (for margin reports)
  weightGrams     Int?                               // for Sendcloud shipping quote
  volumeMl        Int?                               // for the PDP "50 ml" badge
  launchedAt      DateTime?

  // ── Supplier-spec fields ─────────────────────────────────────────────
  // These mirror the columns on Sofia's master-data xlsx so a CSV round
  // trip is lossless. They are language-agnostic (numbers, codes, ISO
  // country) — translatable copy lives on ProductTranslation instead.

  productLine      String?                          // sub-line within the brand, e.g. "Yu.R PRO"
  barcode          String?  @unique                 // EAN-13, used by retail scanners + returns
  shelfLifeMonths  Int?                             // unopened shelf life. Cosmetics convention is months,
                                                    // not years (PAO is opened-life — separate concept).
  originCountry    String?                          // ISO-3166 alpha-2, e.g. "KR" — country product is made in
  hsCode           String?                          // customs/HS classification, used by Sendcloud + invoices
  audienceCategory AudienceCategory @default(UNISEX) // gender/age cohort from the supplier sheet
  inciList         String?                          // full INCI ingredient declaration as one string.
                                                    // Universal nomenclature → not per-locale.

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  translations    ProductTranslation[]
  variants        ProductVariant[]
  categories      ProductCategory[]
  ingredients     ProductIngredient[]
  benefits        ProductBenefit[]
  concerns        ProductConcern[]
  skinTypes       ProductSkinType[]
  media           Media[]
  ritualSteps     RitualStep[]
  relatedFrom     ProductRelated[] @relation("related_from")
  relatedTo       ProductRelated[] @relation("related_to")
  reviews         Review[]
  orderItems      OrderItem[]
  wishlistedBy    WishlistItem[]
  cartItems       CartItem[]
  subscriptions   ProductSubscription[]
  ugcPhotos       UgcPhoto[]

  @@index([status])
  @@index([brandId])
  @@index([isFeatured])
  @@index([isBestseller])
  @@index([barcode])
}

model ProductTranslation {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @db.Uuid
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale           Locale
  name             String
  slug             String
  shortDescription String?
  description      String   // rich HTML from Tiptap
  howToUse         String?  // rich HTML
  // Per-locale safety / regulatory copy. Lives here (not on Product) so
  // Sofia can localise warnings — the legal phrasing differs across NL/FR
  // jurisdictions even though the underlying caution is the same.
  warnings         String?  // plain text or simple HTML
  seoTitle         String?
  seoDescription   String?
  @@unique([productId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

model ProductVariant {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String   @unique
  label       String   // "50 ml", "100 ml", "Travel size"
  price       Decimal? @db.Decimal(10, 2) // null = inherit from Product.price
  comparePrice Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  weightGrams Int?
  barcode     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
  cartItems   CartItem[]
  movements   InventoryMovement[]
  backInStock BackInStockSubscription[]
  subscriptions ProductSubscription[]

  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────
//  BACK-IN-STOCK SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────
// Customer signs up with their email when a variant is out of stock; the
// hourly cron checks each subscription's variant.stock and, if positive,
// fires a "It's back" email and stamps notifiedAt so we never re-notify
// the same row twice.
//
// Why per-variant (not per-product): stock lives on the variant. A product
// with no variants has no stock concept at all, so there's nothing to
// notify on. Keeping the FK required makes the unique index honest in
// Postgres (NULLs aren't equal — would let a single email subscribe many
// times to the same product).

model BackInStockSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  email      String
  variantId  String   @db.Uuid
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locale     Locale   @default(EN)
  createdAt  DateTime @default(now())
  notifiedAt DateTime?

  @@unique([email, variantId])
  @@index([variantId, notifiedAt])
}

model ProductCategory {
  productId  String   @db.Uuid
  categoryId String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([productId, categoryId])
}

model ProductRelated {
  fromId  String   @db.Uuid
  toId    String   @db.Uuid
  reason  String?  // "same ritual", "complementary", "upgrade"
  sortOrder Int    @default(0)
  from    Product  @relation("related_from", fields: [fromId], references: [id], onDelete: Cascade)
  to      Product  @relation("related_to", fields: [toId], references: [id], onDelete: Cascade)
  @@id([fromId, toId])
}

// media (images, video) attached to products or used on homepage banners

enum MediaKind {
  IMAGE
  VIDEO
}

model Media {
  id         String    @id @default(uuid()) @db.Uuid
  productId  String?   @db.Uuid
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind       MediaKind @default(IMAGE)
  url        String    // Supabase storage public URL
  alt        String?
  width      Int?
  height     Int?
  isPrimary  Boolean   @default(false)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  banners    Banner[]

  @@index([productId])
}

// ────────────────────────────────────────────────────────────────────────────
//  INGREDIENTS · BENEFITS · SKIN TYPES · CONCERNS
// ────────────────────────────────────────────────────────────────────────────

model Ingredient {
  id           String   @id @default(uuid()) @db.Uuid
  slug         String   @unique
  inciName     String   // INCI-standard name, e.g. "Centella Asiatica Extract"
  isKeyAsset   Boolean  @default(false) // highlight on PDP with a separate card
  isAllergen   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  translations IngredientTranslation[]
  productLinks ProductIngredient[]
}

model IngredientTranslation {
  id           String   @id @default(uuid()) @db.Uuid
  ingredientId String   @db.Uuid
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  locale       Locale
  displayName  String
  description  String?  // rich HTML — used on /ingredients/[slug]
  @@unique([ingredientId, locale])
}

model ProductIngredient {
  productId    String     @db.Uuid
  ingredientId String     @db.Uuid
  isKey        Boolean    @default(false)
  percentage   Float?
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  @@id([productId, ingredientId])
}

model Benefit {
  id        String              @id @default(uuid()) @db.Uuid
  slug      String              @unique
  icon      String?             // icon key from the design system
  translations BenefitTranslation[]
  productLinks ProductBenefit[]
}

model BenefitTranslation {
  id        String   @id @default(uuid()) @db.Uuid
  benefitId String   @db.Uuid
  benefit   Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  locale    Locale
  label     String
  @@unique([benefitId, locale])
}

model ProductBenefit {
  productId String  @db.Uuid
  benefitId String  @db.Uuid
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  benefit   Benefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  @@id([productId, benefitId])
}

model SkinType {
  id        String              @id @default(uuid()) @db.Uuid
  slug      String              @unique   // "dry" | "oily" | "combo" | "sensitive" | "mature"
  translations SkinTypeTranslation[]
  productLinks ProductSkinType[]
}
model SkinTypeTranslation {
  id         String   @id @default(uuid()) @db.Uuid
  skinTypeId String   @db.Uuid
  skinType   SkinType @relation(fields: [skinTypeId], references: [id], onDelete: Cascade)
  locale     Locale
  label      String
  @@unique([skinTypeId, locale])
}
model ProductSkinType {
  productId  String   @db.Uuid
  skinTypeId String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  skinType   SkinType @relation(fields: [skinTypeId], references: [id], onDelete: Cascade)
  @@id([productId, skinTypeId])
}

model Concern {
  id        String              @id @default(uuid()) @db.Uuid
  slug      String              @unique // "hyperpigmentation" | "fine-lines" | "sun-damage" | …
  translations ConcernTranslation[]
  productLinks ProductConcern[]
}
model ConcernTranslation {
  id        String   @id @default(uuid()) @db.Uuid
  concernId String   @db.Uuid
  concern   Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)
  locale    Locale
  label     String
  @@unique([concernId, locale])
}
model ProductConcern {
  productId String   @db.Uuid
  concernId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  concern   Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)
  @@id([productId, concernId])
}

// ────────────────────────────────────────────────────────────────────────────
//  RITUAL STEPS (on PDP: 01 Cleanse / 02 Treat / 03 Protect)
// ────────────────────────────────────────────────────────────────────────────

model RitualStep {
  id         String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  stepNumber Int       // 1, 2, 3…
  timeOfDay  TimeOfDay @default(ANY)
  translations RitualStepTranslation[]
  @@unique([productId, stepNumber])
}

enum TimeOfDay {
  ANY
  MORNING
  EVENING
}

model RitualStepTranslation {
  id           String     @id @default(uuid()) @db.Uuid
  ritualStepId String     @db.Uuid
  ritualStep   RitualStep @relation(fields: [ritualStepId], references: [id], onDelete: Cascade)
  locale       Locale
  title        String
  body         String     // rich HTML
  @@unique([ritualStepId, locale])
}

// ────────────────────────────────────────────────────────────────────────────
//  CART (session-based, recoverable, works for guests + logged-in users)
// ────────────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique                // stored in an HTTP-only cookie
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id])
  currency   String   @default("EUR")
  locale     Locale   @default(EN)
  notes      String?
  // Abandoned-cart reminders: stamped when the cron sends the nudge so
  // we don't re-send to the same cart. Null = never nudged.
  lastAbandonEmailSentAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      CartItem[]
  @@index([userId])
  @@index([expiresAt])
}

model CartItem {
  id         String          @id @default(uuid()) @db.Uuid
  cartId     String          @db.Uuid
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String          @db.Uuid
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?         @db.Uuid
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int             @default(1)
  unitPrice  Decimal         @db.Decimal(10, 2) // snapshot at add-to-cart
  // Per-line config for non-standard products. Today only gift cards use
  // this — payload shape is { recipientEmail, recipientName?, senderName?,
  // message?, deliverAt? }. STANDARD products leave it null.
  // We deliberately removed the (cartId, productId, variantId) unique
  // constraint that used to guard duplicate-add: per-recipient gift cards
  // need to live on separate lines even when denomination matches.
  // Quantity-bump dedup for STANDARD lines is now enforced in code, where
  // we can branch on `kind === GIFT_CARD`.
  giftCardConfig Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([cartId])
}

// ────────────────────────────────────────────────────────────────────────────
//  ORDERS
// ────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING        // created, not yet paid
  PAID
  FULFILLING     // paid, waiting to ship
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Order {
  id                String        @id @default(uuid()) @db.Uuid
  publicNumber      String        @unique            // "YUR-1042" shown to customer
  userId            String?       @db.Uuid          // null = guest checkout
  user              User?         @relation(fields: [userId], references: [id])
  email             String                            // always captured, even for guests
  locale            Locale        @default(EN)
  currency          String        @default("EUR")
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)

  shippingAddressId String?       @db.Uuid
  billingAddressId  String?       @db.Uuid
  shippingAddress   Address?      @relation("shipping", fields: [shippingAddressId], references: [id])
  billingAddress    Address?      @relation("billing",  fields: [billingAddressId],  references: [id])

  // price breakdown in cents/decimal
  subtotal          Decimal       @db.Decimal(10, 2)
  discountTotal     Decimal       @db.Decimal(10, 2) @default(0)
  shippingTotal     Decimal       @db.Decimal(10, 2) @default(0)
  taxTotal          Decimal       @db.Decimal(10, 2) @default(0)
  grandTotal        Decimal       @db.Decimal(10, 2)

  // payment + fulfilment references
  mollieId          String?       @unique   // Mollie payment id (tr_xxxx)
  molliePaymentUrl  String?
  sendcloudParcelId String?
  trackingNumber    String?
  trackingUrl       String?
  invoiceUrl        String?                 // PDF in Supabase storage

  couponCode        String?
  coupon            Coupon?       @relation(fields: [couponCode], references: [code])
  notes             String?                 // customer's order note
  adminNotes        String?                 // internal

  // Subscription cycle that minted this order, if any. NULL = ad-hoc
  // checkout. Populated by the recurring-charge cron in #181 so admin
  // can answer "is this a sub renewal?" at a glance.
  subscriptionId    String?       @db.Uuid
  subscription      ProductSubscription? @relation("subscription_orders", fields: [subscriptionId], references: [id])

  placedAt          DateTime      @default(now())
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?

  items             OrderItem[]
  events            OrderEvent[]
  returns           ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([placedAt])
}

model OrderItem {
  id           String           @id @default(uuid()) @db.Uuid
  orderId      String           @db.Uuid
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String           @db.Uuid
  product      Product          @relation(fields: [productId], references: [id])
  variantId    String?          @db.Uuid
  variant      ProductVariant?  @relation(fields: [variantId], references: [id])
  nameSnapshot String           // product name at time of order (so renames don't rewrite history)
  skuSnapshot  String
  quantity     Int
  unitPrice    Decimal          @db.Decimal(10, 2)
  lineTotal    Decimal          @db.Decimal(10, 2)
  taxRate      Decimal?         @db.Decimal(5, 4)  // e.g. 0.2100 for 21%

  // Gift-card-specific fields. `giftCardConfig` is copied from the cart
  // line at order placement so the snapshot survives later cart edits.
  // `issuedGiftCardId` is set by the Mollie-paid webhook once a real
  // GiftCard row is minted — gives admin a back-reference to the card
  // that came out of this purchase.
  giftCardConfig    Json?
  issuedGiftCardId  String?  @db.Uuid

  @@index([orderId])
  @@index([issuedGiftCardId])
}

model OrderEvent {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind      String   // "status.changed", "email.sent.confirmation", "refund.issued", …
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())
  @@index([orderId])
}

// ────────────────────────────────────────────────────────────────────────────
//  RETURNS / RMA
//
//  The customer-facing return flow.  One ReturnRequest belongs to exactly
//  one Order but may cover a subset of its lines (ReturnItem rows).
//  Sofia reviews each request and can move it through the status enum —
//  the email templates in src/lib/email/return-*.ts are triggered by
//  those transitions.
// ────────────────────────────────────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED     // customer just submitted — awaiting Sofia
  APPROVED      // Sofia accepted, label/address issued to customer
  RECEIVED      // parcel arrived at warehouse
  REFUNDED      // money returned to customer
  REJECTED      // outside window / damaged beyond policy
  CANCELLED     // customer withdrew request
}

enum ReturnReason {
  CHANGED_MIND
  WRONG_ITEM
  DAMAGED
  DEFECTIVE
  ARRIVED_LATE
  ALLERGIC_REACTION
  OTHER
}

model ReturnRequest {
  id              String        @id @default(uuid()) @db.Uuid
  /// Short code the customer sees, e.g. "YUR-1042-R1".
  publicNumber    String        @unique

  orderId         String        @db.Uuid
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// Set when the requester is a signed-in customer.  Left null for any
  /// future guest-return flow (which would need email verification).
  userId          String?       @db.Uuid
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  status          ReturnStatus  @default(REQUESTED)
  reason          ReturnReason  @default(OTHER)
  /// Customer's free-text explanation (optional).
  details         String?
  /// Internal notes from Sofia / admins — never shown to customer.
  adminNotes      String?

  /// Monetary side (populated after Sofia reviews — not at request time).
  refundAmount    Decimal?      @db.Decimal(10, 2)
  refundedAt      DateTime?

  /// Logistics
  trackingNumber  String?
  trackingUrl     String?
  receivedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           ReturnItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ReturnItem {
  id             String         @id @default(uuid()) @db.Uuid
  returnId       String         @db.Uuid
  return         ReturnRequest  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  /// Snapshot to the original order line — lets us preserve historical
  /// quantities and price even if the OrderItem is edited later.
  orderItemId    String         @db.Uuid

  /// Denormalised so the row survives product renames and OrderItem
  /// cascades.  Email templates read from here.
  nameSnapshot   String
  skuSnapshot    String
  quantity       Int
  unitPrice      Decimal        @db.Decimal(10, 2)
  lineTotal      Decimal        @db.Decimal(10, 2)

  @@index([returnId])
  @@index([orderItemId])
}

// ────────────────────────────────────────────────────────────────────────────
//  COUPONS / DISCOUNTS
// ────────────────────────────────────────────────────────────────────────────

enum DiscountKind {
  PERCENT          // "10% off"
  FIXED            // "€5 off"
  FREE_SHIPPING
}

model Coupon {
  code          String        @id
  kind          DiscountKind
  value         Decimal       @db.Decimal(10, 2) // percent (0-100) or fixed EUR
  minSubtotal   Decimal?      @db.Decimal(10, 2)
  maxRedemptions Int?
  redemptionsUsed Int         @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean       @default(true)
  firstOrderOnly Boolean      @default(false)
  createdAt     DateTime      @default(now())
  orders        Order[]
}

// ────────────────────────────────────────────────────────────────────────────
//  USER-GENERATED CONTENT
//  Manually curated photos of customers using a product. Surfaced on the
//  PDP under "How customers use this". Sofia uploads via /admin/ugc and
//  taps each photo to a single product. Soft-deleteable.
// ────────────────────────────────────────────────────────────────────────────

model UgcPhoto {
  id                 String   @id @default(uuid()) @db.Uuid
  productId          String   @db.Uuid
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl           String   // Supabase Storage URL
  customerFirstName  String?  // optional caption byline
  caption            String?  // optional 1-line note
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([productId, isActive])
}

// ────────────────────────────────────────────────────────────────────────────
//  GIFT CARDS
//  Separate from Coupon because the mental model is different — a coupon is
//  a discount rule (used N times), a gift card is a money balance (drawn
//  down by amount). Status is computed off balance + expiry but cached for
//  cheap admin filtering.
// ────────────────────────────────────────────────────────────────────────────

enum GiftCardStatus {
  ACTIVE     // balance > 0 and not expired
  DEPLETED   // balance == 0
  VOID       // admin manually voided (e.g. fraud)
  EXPIRED    // past expiresAt
}

model GiftCard {
  id              String         @id @default(uuid()) @db.Uuid
  code            String         @unique          // "GIFT-XXXXXXXX" — what the customer types
  initialBalance  Decimal        @db.Decimal(10, 2) // amount sold for / issued at
  balance         Decimal        @db.Decimal(10, 2) // remaining balance, decrements per redemption
  currency        String         @default("EUR")
  status          GiftCardStatus @default(ACTIVE)
  recipientEmail  String                            // who the card was sent to
  recipientName   String?
  senderName      String?                           // optional, shown in the gift email
  senderEmail     String?                           // buyer's email — kept distinct from recipient
                                                    // for "send to a friend" flows.
  message         String?                           // optional gift note
  // "self" = bought for personal use; "friend" = bought to send. Drives
  // which email template fires (recipient + buyer-confirmation).
  deliveryMode    String?                           // "self" | "friend"
  expiresAt       DateTime?                         // null = never. Default 1 year set in code.
  // Optional: which order purchased this gift card (null for admin-issued).
  purchaseOrderId String?        @db.Uuid
  // Optional: which OrderItem on that order this card came from. Lets the
  // admin link card → line and the post-payment hook know the per-line
  // config (recipient details, message). Unique because each OrderItem
  // mints exactly one card today (quantity is forced to 1 for gift cards).
  purchaseOrderItemId String?    @unique @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  redemptions     GiftCardRedemption[]

  @@index([status])
  @@index([recipientEmail])
  @@index([senderEmail])
  @@index([purchaseOrderId])
}

// One row per redemption (per order). Lets us audit + reverse a redemption
// if the order is cancelled/refunded.
model GiftCardRedemption {
  id          String   @id @default(uuid()) @db.Uuid
  giftCardId  String   @db.Uuid
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId     String   @db.Uuid
  amountUsed  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  // A given gift card can only be applied once per order (otherwise a
  // double-click would double-deduct).
  @@unique([giftCardId, orderId])
  @@index([orderId])
}

// ────────────────────────────────────────────────────────────────────────────
//  LOYALTY POINTS + REFERRALS
//  Points accrue on paid orders (1 point per €1 spent, configurable in
//  code) and burn on coupons issued from the customer dashboard. Refer-
//  a-friend uses two coupon codes per pair: one for the friend (10% off
//  first order), one for the referrer (10% off their next order, minted
//  the moment the friend's order is paid).
// ────────────────────────────────────────────────────────────────────────────

enum LoyaltyEventKind {
  EARNED_ORDER       // accrued from a paid order
  REDEEMED_COUPON    // burned points to mint a discount coupon
  ADJUSTED_ADMIN     // manual admin adjustment (gift / clawback)
  REFERRAL_BONUS     // bonus points awarded for a successful referral
  EXPIRED            // points cleared by the annual expiry sweep
}

model LoyaltyAccount {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @unique @db.Uuid
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Points cached for cheap display — equal to sum(events.delta).
  pointsBalance Int              @default(0)
  // Lifetime accrual — informational, never decremented.
  pointsLifetime Int             @default(0)
  // Customer's personal referral code, e.g. "SOFIA-K4M7". Shareable
  // forever. Friends apply at checkout to mint the referee discount.
  referralCode  String           @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  events        LoyaltyEvent[]

  @@index([referralCode])
}

model LoyaltyEvent {
  id          String           @id @default(uuid()) @db.Uuid
  accountId   String           @db.Uuid
  account     LoyaltyAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  kind        LoyaltyEventKind
  // Signed integer — positive accrual, negative redemption / expiry.
  delta       Int
  // Free-text reason shown in the customer's history table.
  reason      String
  // Optional links — order that earned the points, coupon that burnt them, etc.
  orderId     String?          @db.Uuid
  couponCode  String?
  createdAt   DateTime         @default(now())

  @@index([accountId])
  @@index([orderId])
}

// Two-sided referral tracking. A row is created the moment the
// referee uses the referral coupon at checkout; settled on first paid
// order so we can pay the referrer their bonus without rewarding
// abandoned carts.
model Referral {
  id              String     @id @default(uuid()) @db.Uuid
  referrerUserId  String     @db.Uuid
  refereeUserId   String?    @db.Uuid             // null until the friend places their first order
  refereeOrderId  String?    @db.Uuid             // first paid order from the referee
  refereeEmail    String                          // captured at checkout for guest cases
  status          ReferralStatus @default(PENDING)
  rewardCouponCode String?                        // code minted for the referrer once status flips to REWARDED
  createdAt       DateTime   @default(now())
  rewardedAt      DateTime?

  @@index([referrerUserId])
  @@index([status])
}

enum ReferralStatus {
  PENDING     // referee has used the code at checkout, hasn't paid yet
  REWARDED    // referee paid; referrer got their coupon
  CANCELLED   // referee order failed / refunded
}

// ────────────────────────────────────────────────────────────────────────────
//  SUBSCRIBE & SAVE
//  Customers can sign up to receive a product on a recurring cadence (30,
//  60, 90 days) at a discount. Mollie's "first payment" + "mandate" model
//  drives the recurring charges; we cache the mandate id so subsequent
//  cycles don't need a customer-present checkout.
// ────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  PENDING_FIRST_PAYMENT  // signup created, Mollie hasn't confirmed the first payment yet
  ACTIVE                 // mandate live, scheduled to run on nextRunAt
  PAUSED                 // customer-initiated pause (kept indefinitely)
  CANCELLED              // hard cancel — won't re-run
  PAYMENT_FAILED         // last cycle's charge failed, awaiting customer fix
}

model ProductSubscription {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @db.Uuid
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String              @db.Uuid
  product         Product             @relation(fields: [productId], references: [id])
  variantId       String?             @db.Uuid
  variant         ProductVariant?     @relation(fields: [variantId], references: [id])
  quantity        Int                 @default(1)

  // Mollie linkage
  mollieCustomerId String?            // mollie customer id (cst_xxx) — created once at first signup
  mollieMandateId  String?            // mollie mandate id — needed for charging without customer present
  mollieFirstPaymentId String?        // tr_xxx of the initial transaction that minted the mandate

  // Cadence + state
  cadenceDays     Int                 // 30 / 60 / 90 typically
  discountPercent Decimal             @default(0) @db.Decimal(5, 2) // e.g. 10.00 for 10% off

  status          SubscriptionStatus  @default(PENDING_FIRST_PAYMENT)
  nextRunAt       DateTime?           // when the cron should attempt the next charge — null when PAUSED/CANCELLED
  lastRunAt       DateTime?
  lastFailureAt   DateTime?
  consecutiveFailures Int             @default(0)

  // Snapshotted shipping address — copied from the user at signup so a
  // later address edit doesn't retroactively reroute pending shipments.
  shippingAddressId String?           @db.Uuid
  shippingAddress   Address?          @relation(fields: [shippingAddressId], references: [id])

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  cancelledAt     DateTime?

  // Each scheduled cycle creates a normal Order; we link them back so the
  // /account/subscriptions page can show "next run" and "past 6 cycles".
  childOrders     Order[]             @relation("subscription_orders")

  @@index([userId])
  @@index([status, nextRunAt])
}

// ────────────────────────────────────────────────────────────────────────────
//  REVIEWS / WISHLIST
// ────────────────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id])
  rating     Int      // 1-5
  title      String?
  body       String
  isVerified Boolean  @default(false) // true if tied to an order of this product
  isPublished Boolean @default(false) // admin moderation
  locale     Locale   @default(EN)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([isPublished])
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

// ────────────────────────────────────────────────────────────────────────────
//  JOURNAL (editorial posts) + STATIC PAGES
// ────────────────────────────────────────────────────────────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model JournalPost {
  id          String      @id @default(uuid()) @db.Uuid
  status      PostStatus  @default(DRAFT)
  publishedAt DateTime?
  // Card thumbnail. Rendered at 4:5 portrait on the homepage teaser and
  // /journal listing grid. Upload at ~1200×1500 for a clean 4:5 crop.
  coverUrl    String?
  // Article hero — rendered full-width at 16:9 landscape at the top of
  // /journal/[slug]. Upload at ~1600×900. Falls back to `coverUrl` when
  // null so old articles keep rendering without admin intervention.
  heroUrl     String?
  authorName  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  translations JournalPostTranslation[]
}

model JournalPostTranslation {
  id          String      @id @default(uuid()) @db.Uuid
  postId      String      @db.Uuid
  post        JournalPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  slug        String
  excerpt     String?
  body        String      // rich HTML
  seoTitle    String?
  seoDescription String?
  @@unique([postId, locale])
  @@unique([locale, slug])
}

model Page {
  id         String  @id @default(uuid()) @db.Uuid
  key        String  @unique   // "about" | "faq" | "shipping" | "terms" | "privacy" | "cookies" | "imprint"
  isActive   Boolean @default(true)
  updatedAt  DateTime @updatedAt
  translations PageTranslation[]
}
model PageTranslation {
  id     String @id @default(uuid()) @db.Uuid
  pageId String @db.Uuid
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale Locale
  title  String
  body   String  // rich HTML
  seoTitle String?
  seoDescription String?
  @@unique([pageId, locale])
}

// ────────────────────────────────────────────────────────────────────────────
//  HOMEPAGE — banners + seasonal campaigns (admin-editable)
// ────────────────────────────────────────────────────────────────────────────

model Banner {
  id         String   @id @default(uuid()) @db.Uuid
  placement  String   // "home.hero" | "home.announcement" | "shop.top" | …
  mediaId    String?  @db.Uuid
  media      Media?   @relation(fields: [mediaId], references: [id])
  ctaHref    String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  translations BannerTranslation[]
  @@index([placement, isActive])
}
model BannerTranslation {
  id       String @id @default(uuid()) @db.Uuid
  bannerId String @db.Uuid
  banner   Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  locale   Locale
  headline String?
  subhead  String?
  ctaLabel String?
  @@unique([bannerId, locale])
}

// ────────────────────────────────────────────────────────────────────────────
//  SITE COPY — admin-editable text across the public site
// ────────────────────────────────────────────────────────────────────────────
//  Any row here OVERRIDES the corresponding key in the JSON message catalogue.
//  `section` groups related keys (e.g. "home.hero", "footer"), `field` is the
//  specific slot ("eyebrow", "title_pre", "lede", …). The full taxonomy of
//  allowed (section, field) pairs lives in code as SITE_COPY_SCHEMA so the
//  admin UI can render the right form without introspecting the table.
//
//  Empty DB = defaults from messages/{locale}.json. Sofia can fill rows
//  locale-by-locale without blowing away fallbacks.

model SiteCopy {
  id        String   @id @default(uuid()) @db.Uuid
  section   String   // "home.hero" | "home.bestsellers" | "footer" | …
  field     String   // "eyebrow" | "title_pre" | "lede" | "cta_primary" | …
  locale    Locale
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique([section, field, locale])
  @@index([section, locale])
}

// ────────────────────────────────────────────────────────────────────────────
//  TESTIMONIALS — homepage "Voices" strip, admin-editable
// ────────────────────────────────────────────────────────────────────────────
//  Independent of product Reviews — these are editorial quotes Sofia curates
//  for the homepage. Translations are per-locale so the same testimonial can
//  be rewritten idiomatically in EN/NL/FR/RU.

model Testimonial {
  id         String   @id @default(uuid()) @db.Uuid
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  rating     Int      @default(5)   // 1-5, rendered as stars
  verified   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  translations TestimonialTranslation[]

  @@index([isActive, sortOrder])
}

model TestimonialTranslation {
  id            String      @id @default(uuid()) @db.Uuid
  testimonialId String      @db.Uuid
  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  locale        Locale
  quote         String
  authorName    String
  productName   String?     // optional "— on Ginseng Serum"

  @@unique([testimonialId, locale])
}

// ────────────────────────────────────────────────────────────────────────────
//  NEWSLETTER — subscribers, double opt-in, GDPR consent
// ────────────────────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  locale        Locale    @default(EN)
  source        String?   // "footer", "checkout", "popup", …
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  tokenHash     String?   // double-opt-in token (hashed)
  createdAt     DateTime  @default(now())
  @@index([confirmedAt])
}

// ────────────────────────────────────────────────────────────────────────────
//  AI CONCIERGE — conversations, messages, tool calls (for analytics)
// ────────────────────────────────────────────────────────────────────────────

model AiConversation {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @db.Uuid
  user       User?     @relation(fields: [userId], references: [id])
  sessionId  String                              // set for guests via cookie
  locale     Locale    @default(EN)
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  rating     Int?                                // thumbs up/down feedback
  ledToPurchase Boolean @default(false)
  orderId    String?   @db.Uuid
  messages   AiMessage[]
  @@index([sessionId])
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiRole
  content        String
  toolName       String?
  toolArgs       Json?
  toolResult     Json?
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime       @default(now())
  @@index([conversationId])
}

// ────────────────────────────────────────────────────────────────────────────
//  CONTACT — inbound messages from the public contact form
// ────────────────────────────────────────────────────────────────────────────
//  Saved for audit even if Resend delivery fails.  Sofia reads/archives in
//  /admin/contact; replies happen out-of-band in her normal email client.

enum ContactSubject {
  GENERAL         // "I have a question"
  ORDER           // order enquiry, tracking, amend
  RETURN          // return or refund
  WHOLESALE       // partnership / wholesale / press
  TECHNICAL       // site bug / account issue
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id          String          @id @default(uuid()) @db.Uuid
  locale      Locale          @default(EN)
  name        String
  email       String
  phone       String?
  subject     ContactSubject  @default(GENERAL)
  orderNumber String?                         // free-text reference, e.g. "YUR-20260422-0001"
  message     String          @db.Text
  status      ContactStatus   @default(NEW)
  ipHash      String?                          // GDPR-minimised
  userAgent   String?
  userId      String?         @db.Uuid         // if logged-in, link to their account
  user        User?           @relation(fields: [userId], references: [id])
  notifiedAt  DateTime?                        // admin email actually sent
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([status, createdAt])
  @@index([email])
}

// ────────────────────────────────────────────────────────────────────────────
//  SETTINGS — simple key/value for shop config the admin can edit
// ────────────────────────────────────────────────────────────────────────────
//  Examples: "ai.systemPrompt", "shipping.freeThreshold", "checkout.allowedCountries"

model Setting {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid
}

// ────────────────────────────────────────────────────────────────────────────
//  GDPR — consent log (cookies, marketing opt-ins) for audit trail
// ────────────────────────────────────────────────────────────────────────────

model ConsentLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  sessionId String?
  ipHash    String?                 // hashed IP for GDPR minimisation
  userAgent String?
  purpose   String                  // "necessary" | "analytics" | "marketing"
  granted   Boolean
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([sessionId])
}

// ────────────────────────────────────────────────────────────────────────────
//  REDIRECTS — admin-editable URL aliases, keeps bookmarks + SEO alive when
//  Sofia renames a product, category, or brand slug.
// ────────────────────────────────────────────────────────────────────────────
//  fromPath  → the OLD path the visitor hit (locale-prefixed, e.g. "/en/shop/old-serum")
//  toPath    → the NEW path to send them to ("/en/shop/new-serum")
//  code      → PERMANENT (301, SEO-transferring) or TEMPORARY (302)
//  source    → "auto:product-slug" | "auto:category-slug" | "manual" — lets us
//              distinguish redirects Sofia typed vs. auto-inserted ones she can
//              prune later.
//  hits / lastHitAt — so Sofia can see which ones are still earning their keep.

enum RedirectCode {
  PERMANENT // HTTP 301 — permanent move, search engines transfer rank
  TEMPORARY // HTTP 302 — temporary
}

model Redirect {
  id         String       @id @default(uuid()) @db.Uuid
  fromPath   String       @unique             // starts with "/", full locale-prefixed path
  toPath     String                            // starts with "/"
  code       RedirectCode @default(PERMANENT)
  source     String?                           // "auto:product-slug" | "manual" | …
  note       String?                           // Sofia's own reminder to herself
  hits       Int          @default(0)
  lastHitAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([source])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
//  AUDIT LOG
// ────────────────────────────────────────────────────────────────────────────
//  A linear trail of admin mutations so Sofia can see who changed what and
//  roll back if something goes wrong. Entries are append-only (never edited)
//  and NOT FK'd to User — we store an `actorEmail` snapshot so the row remains
//  legible after the User row is tombstoned by GDPR erasure.
//
//  `action` convention: "{entity}.{verb}" — e.g. "product.update", "order.refund",
//  "coupon.delete", "redirect.create". This keeps the list filterable by
//  simple prefix search.
//
//  `meta` is a small JSON blob the caller fills with whatever context helps —
//  changed fields, before/after snippets, ids, etc. Keep it under a few KB.

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  // Actor — null for system actions (cron jobs, webhooks).
  actorId     String?   @db.Uuid
  actorEmail  String?   // snapshot so the entry survives user deletion
  action      String    // "{entity}.{verb}" — e.g. "product.update"
  entityType  String?   // "Product" | "Order" | "Redirect" | …
  entityId    String?   // UUID or slug — whatever identifies the row
  summary     String    // one-line human-readable description
  meta        Json?     // small structured details (changed fields, etc.)
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
}

// ────────────────────────────────────────────────────────────────────────────
//  INVENTORY MOVEMENTS
// ────────────────────────────────────────────────────────────────────────────
//  Every time a variant's stock changes, append a row here. Lets Sofia see
//  exactly where stock went — sold, returned, adjusted, imported — so she
//  can reconcile when the warehouse count disagrees with the system count.
//
//  Current stock still lives on ProductVariant.stock (fast reads); this log
//  is the ledger that explains how it got there.

enum InventoryReason {
  SALE           // customer placed an order
  CANCEL         // order cancelled → restock
  REFUND         // order refunded → restock (full or partial)
  RETURN         // RMA received → restock
  ADJUSTMENT     // admin hand-edit from product page
  CSV_IMPORT     // bulk upload set a new stock number
  INITIAL        // product/variant just created with initial stock
  OTHER
}

model InventoryMovement {
  id          String   @id @default(uuid()) @db.Uuid
  variantId   String   @db.Uuid
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  delta       Int      // signed — positive adds stock, negative removes
  stockAfter  Int      // snapshot for quick charts without recomputing
  reason      InventoryReason
  orderId     String?  @db.Uuid   // optional link to the order that caused it
  actorId     String?  @db.Uuid   // admin who acted (null for automatic)
  actorEmail  String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([variantId, createdAt])
  @@index([orderId])
  @@index([reason])
  @@index([createdAt])
}
