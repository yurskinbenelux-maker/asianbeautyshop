# ─── YU.R Skin Solution · .env.example ───────────────────────────────────────
# Copy this file to .env.local for local dev, and set the same vars in
# Hostinger hPanel → Node.js app → Environment Variables for production.
# NEVER commit .env.local to git.

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yurskinsolution.eu"
NEXT_PUBLIC_SITE_NAME="YU.R Skin Solution"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_SUPPORTED_LOCALES="en,nl,fr,ru"

# ─── Supabase (Postgres + Auth + Storage) ───────────────────────────────────
# Create a project at https://supabase.com, then Settings → Database → Connection pooler
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"  # server-only, never expose to client
SUPABASE_STORAGE_BUCKET="yur-media"

# ─── Mollie (payments) ──────────────────────────────────────────────────────
# https://www.mollie.com → Developers → API keys
MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxx"         # swap to live_ when going live
MOLLIE_PROFILE_ID="pfl_xxxxxxxxxxxx"             # for admin display; optional
# Optional shared secret appended to the webhook URL as ?token=… so the
# endpoint can ignore spammed payment ids from attackers. If unset we
# reuse CRON_SECRET — still better than nothing.
MOLLIE_WEBHOOK_SECRET=""

# ─── Anthropic (AI concierge) ───────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxx"
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Resend (transactional email) ───────────────────────────────────────────
# Get the API key from https://resend.com → API Keys.
# The From addresses must be at a Resend-verified domain
# (https://resend.com → Domains → add yurskinsolution.eu and follow the
# DNS records Resend shows you; add them to Hostinger DNS, then verify).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
RESEND_FROM_NEWSLETTER="YU.R Letter <newsletter@yurskinsolution.eu>"
RESEND_FROM_TRANSACTIONAL="YU.R Skin Solution <donotreply@yurskinsolution.eu>"
RESEND_REPLY_TO="hello@yurskinsolution.eu"
# Signing secret for /api/webhooks/resend (Resend dashboard → Webhooks)
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxx"
# Where admin-only notifications (new orders, low stock) are delivered.
ADMIN_NOTIFICATION_EMAIL="admin@yurskinsolution.eu"

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for /api/cron/* endpoints (low-stock digest, etc.).
# Hostinger cron: `curl -H "Authorization: Bearer $CRON_SECRET" <endpoint>`.
CRON_SECRET="xxx"

# ─── Sendcloud (shipping labels & rates) ────────────────────────────────────
SENDCLOUD_PUBLIC_KEY="xxx"
SENDCLOUD_SECRET_KEY="xxx"

# ─── Plausible / analytics (optional) ──────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yurskinsolution.eu"

# ─── Sentry (error tracking, optional) ─────────────────────────────────────
SENTRY_DSN=""

# ─── Admin ──────────────────────────────────────────────────────────────────
ADMIN_ALLOWED_EMAILS="sofia@yurskinsolution.eu,max@kelmus.be"

# ── Groq (AI skin concierge — free tier) ─────────────────────────────
# Optional. If unset, the orb falls back to a rule-based skin quiz.
# Sign up at console.groq.com (free, no credit card), create key, paste here.
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
